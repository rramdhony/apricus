/
  Cache-Control: no-cache

/index.html
  Cache-Control: no-cache

# Security (Studio26 hardening, June 2026)
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://challenges.cloudflare.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data: https://assets.apricus-mu.com https://cdn.jsdelivr.net; connect-src 'self' https://api.web3forms.com https://cloudflareinsights.com; form-action 'self' https://api.web3forms.com; frame-src https://maps.google.com https://www.google.com https://challenges.cloudflare.com; object-src 'none'; base-uri 'self'; frame-ancestors 'none'
